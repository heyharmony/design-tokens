{
  "$description": "Universal layout tokens — spacing and border-radius. Mode/preset-independent.",
  "spacing": {
    "0": { "$value": "0", "$type": "dimension" },
    "0-5": { "$value": "0.25rem", "$type": "dimension" },
    "1": { "$value": "0.5rem", "$type": "dimension" },
    "1-5": { "$value": "0.75rem", "$type": "dimension" },
    "2": { "$value": "1rem", "$type": "dimension" },
    "3": { "$value": "1.5rem", "$type": "dimension" },
    "4": { "$value": "2rem", "$type": "dimension" },
    "5": { "$value": "2.5rem", "$type": "dimension" },
    "6": { "$value": "3rem", "$type": "dimension" },
    "8": { "$value": "4rem", "$type": "dimension" },
    "10": { "$value": "5rem", "$type": "dimension" },
    "12": { "$value": "6rem", "$type": "dimension" }
  },
  "radius": {
    "none": { "$value": "0", "$type": "dimension" },
    "sm": { "$value": "0.25rem", "$type": "dimension" },
    "md": { "$value": "0.5rem", "$type": "dimension" },
    "lg": { "$value": "0.75rem", "$type": "dimension" },
    "xl": { "$value": "1rem", "$type": "dimension" },
    "2xl": { "$value": "1.5rem", "$type": "dimension" },
    "full": { "$value": "9999px", "$type": "dimension" }
  }
